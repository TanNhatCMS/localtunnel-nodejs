{
  "name": "localtunnel-nodejs",
  "description": "Expose localhost to the world",
  "version": "2.0.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/TanNhatCMS/localtunnel-nodejs.git"
  },
  "author": "Roman Shtylman <shtylman@gmail.com>",
  "contributors": [
    "Roman Shtylman <shtylman@gmail.com>",
    "Gert Hengeveld <gert@hichroma.com>",
    "Tom Coleman <tom@hichroma.com>",
    "TanNhatCMS"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lt": "dist/bin/lt.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --loader ts-node/esm src/index.ts",
    "test": "mocha -r ts-node/register test/*.spec.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepare": "yarn build"
  },
  "dependencies": {
    "axios": "1.8.2",
    "debug": "4.3.2",
    "openurl": "1.1.1",
    "yargs": "17.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.4",
    "@types/openurl": "^1.0.3",
    "@types/yargs": "^17.0.33",
    "babel-eslint": "^10.1.0",
    "eslint": "^9.29.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.0",
    "mocha": "^11.7.1",
    "prettier": "^3.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  },
  "engines": {
    "node": ">=8.3.0"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
